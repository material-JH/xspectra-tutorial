 &input_xspectra
    calculation='xanes_dipole',
    prefix='SrTiO3_OK_FCH',
    outdir='./tmp/',
    xniter=2000,
    xcheck_conv=50,
    xepsilon(1)=1.0,
    xepsilon(2)=0.0,
    xepsilon(3)=0.0,
    xiabs=3,
    x_save_file='O_Kedge_FCH.sav',
    xerror=0.001,
 /
 &plot
    xnepoint=1000,
    xgamma=0.8,
    xemin=-10.0,
    xemax=40.0,
    terminator=.true.,
    cut_occ_states=.true.,
 /
 &pseudos
    filecore='O.wfc',
    r_paw(1)=1.2,
 /
 &cut_occ
    cut_desmooth=0.1,
 /
4 4 4 1 1 1
