#!/usr/bin/env bash
#PBS -N xspectra-diamond
#PBS -A qe
#PBS -q norm_skl
#PBS -l select=1:ncpus=4:mpiprocs=4
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

cd "$PBS_O_WORKDIR"
source ./env.sh

# Keep the tutorial examples at 4 MPI ranks. Some PBS systems allocate a full
# node even for this request, so do not derive the tutorial rank count from PBS_NP.
export NPROCS=4
export MPI_RUN="mpirun -np $NPROCS"

bash run_all_examples.sh diamond-only
python3 plot_spectra.py
