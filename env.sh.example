#!/usr/bin/env bash
# XSpectra tutorial environment configuration.
#
# Copy this file to env.sh and edit it for your supercomputer:
#   cp env.sh.example env.sh
#   vim env.sh
#
# Beginner note:
#   Do NOT type /path/to/q-e literally. First load the Quantum ESPRESSO
#   module for your cluster, then let this file find pw.x automatically.
#   To see what path the module provides, run:
#     command -v pw.x
#   If it prints /apps/qe/7.3/bin/pw.x, then:
#     BIN_DIR=/apps/qe/7.3/bin
#     QE_ROOT=/apps/qe/7.3
#
# This file prints a short status summary when you run it directly:
#   bash env.sh.example
# or when you source the copied env.sh in an interactive shell:
#   source env.sh
# To silence the summary in advanced scripts, set XSPECTRA_ENV_QUIET=1.

_XSPECTRA_ENV_RAN_AS_SCRIPT=0
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    _XSPECTRA_ENV_RAN_AS_SCRIPT=1
fi

# -----------------------------------------------------------------------------
# 1. Load the software modules for your cluster.
# -----------------------------------------------------------------------------
# The exact module names are different on every supercomputer. Ask the
# instructor or run these commands on the login node to explore available names:
#   module avail quantum
#   module avail qe
#   module avail espresso
#
# Uncomment and edit the examples below. Keep only lines that work on your site.
# module purge
# module load quantum-espresso/7.3
# module load openmpi
# module load python/3.10

# -----------------------------------------------------------------------------
# 2. Find Quantum ESPRESSO executables.
# -----------------------------------------------------------------------------
# After the module is loaded, pw.x should be visible in your PATH. The commands
# below auto-fill PW_BIN, XSPECTRA_BIN, LD1_BIN, BIN_DIR, and QE_ROOT when possible.
# If auto-detection fails, run "command -v pw.x" by hand and set BIN_DIR manually.

if command -v pw.x >/dev/null 2>&1; then
    export PW_BIN="${PW_BIN:-$(command -v pw.x)}"
fi

if command -v xspectra.x >/dev/null 2>&1; then
    export XSPECTRA_BIN="${XSPECTRA_BIN:-$(command -v xspectra.x)}"
fi

if command -v ld1.x >/dev/null 2>&1; then
    export LD1_BIN="${LD1_BIN:-$(command -v ld1.x)}"
fi

# Most QE installations place pw.x in QE_ROOT/bin. Derive those folders from pw.x.
if [ -z "${BIN_DIR:-}" ] && [ -n "${PW_BIN:-}" ]; then
    export BIN_DIR="$(cd "$(dirname "$PW_BIN")" && pwd)"
fi

if [ -z "${QE_ROOT:-}" ] && [ -n "${BIN_DIR:-}" ]; then
    export QE_ROOT="$(cd "$BIN_DIR/.." && pwd)"
fi

# If your cluster does not expose pw.x through a module, set these manually.
# Example: command -v pw.x printed /apps/qe/7.3/bin/pw.x
# export BIN_DIR=/apps/qe/7.3/bin
# export QE_ROOT=/apps/qe/7.3
# export PW_BIN=$BIN_DIR/pw.x
# export XSPECTRA_BIN=$BIN_DIR/xspectra.x
# export LD1_BIN=$BIN_DIR/ld1.x

# Fallbacks for manual settings above. These also cover clusters where pw.x is
# visible but xspectra.x/ld1.x are not listed separately by "command -v".
if [ -z "${BIN_DIR:-}" ] && [ -n "${QE_ROOT:-}" ]; then
    export BIN_DIR="$QE_ROOT/bin"
fi

if [ -z "${PW_BIN:-}" ] && [ -n "${BIN_DIR:-}" ]; then
    export PW_BIN="$BIN_DIR/pw.x"
fi

if [ -z "${XSPECTRA_BIN:-}" ] && [ -n "${BIN_DIR:-}" ]; then
    export XSPECTRA_BIN="$BIN_DIR/xspectra.x"
fi

if [ -z "${LD1_BIN:-}" ] && [ -n "${BIN_DIR:-}" ]; then
    export LD1_BIN="$BIN_DIR/ld1.x"
fi

# -----------------------------------------------------------------------------
# 3. Find XSpectra helper files and example pseudopotentials.
# -----------------------------------------------------------------------------
# These are often inside the QE source tree, but some clusters install only the
# executables. If check_setup.sh says these paths are missing, ask the instructor
# for the local XSpectra tools/examples path and set TOOLS_DIR and
# EXAMPLE_PSEUDO_DIR below.

if [ -n "${QE_ROOT:-}" ]; then
    export TOOLS_DIR="${TOOLS_DIR:-$QE_ROOT/XSpectra/tools}"
    export EXAMPLE_PSEUDO_DIR="${EXAMPLE_PSEUDO_DIR:-$QE_ROOT/XSpectra/examples/pseudo}"
fi

# Manual examples if the defaults above do not exist:
# export TOOLS_DIR=/apps/qe/7.3/XSpectra/tools
# export EXAMPLE_PSEUDO_DIR=/apps/qe/7.3/XSpectra/examples/pseudo

# -----------------------------------------------------------------------------
# 4. Parallel execution settings.
# -----------------------------------------------------------------------------
# Tutorial default parallelism. For scheduled jobs, set this from SLURM_NTASKS,
# PBS_NP, or the number of MPI ranks allocated by your scheduler.
export NPROCS="${NPROCS:-4}"

# MPI launcher. Inside Slurm jobs, prefer: export MPI_RUN="srun -n $NPROCS"
# Outside Slurm, many clusters use: export MPI_RUN="mpirun -np $NPROCS"
export MPI_RUN="${MPI_RUN:-mpirun -np $NPROCS}"

# Optional scratch root. The scripts currently use per-example ./tmp directories
# for teaching clarity. Advanced users may point this to node-local or project
# scratch and adapt outdir accordingly.
export XSPECTRA_SCRATCH="${XSPECTRA_SCRATCH:-./tmp}"

# -----------------------------------------------------------------------------
# 5. Print a beginner-friendly status summary.
# -----------------------------------------------------------------------------
# A silent setup file feels like "nothing happened" to beginners. Print a short
# summary when the file is run directly, sourced in an interactive shell, or when
# XSPECTRA_ENV_VERBOSE=1 is set. Batch scripts can stay quiet with
# XSPECTRA_ENV_QUIET=1.

_xspectra_env_print_status() {
    echo ""
    echo "XSpectra environment status"
    echo "----------------------------"

    if [ "$_XSPECTRA_ENV_RAN_AS_SCRIPT" = "1" ]; then
        echo "NOTE You ran this file as a script. This is useful as a quick check,"
        echo "     but it does not permanently set variables in your current shell."
        echo "     Normal tutorial setup: cp env.sh.example env.sh; vim env.sh; bash check_setup.sh"
    else
        echo "INFO env.sh was sourced into the current shell."
    fi

    if [ -n "${PW_BIN:-}" ] && [ -x "$PW_BIN" ]; then
        echo "PASS pw.x: $PW_BIN"
    elif [ -n "${PW_BIN:-}" ]; then
        echo "WARN pw.x: path is set but not executable: $PW_BIN"
    else
        echo "WARN pw.x: not found. Edit the module load lines, then try: command -v pw.x"
    fi

    if [ -n "${XSPECTRA_BIN:-}" ] && [ -x "$XSPECTRA_BIN" ]; then
        echo "PASS xspectra.x: $XSPECTRA_BIN"
    elif [ -n "${XSPECTRA_BIN:-}" ]; then
        echo "WARN xspectra.x: path is set but not executable: $XSPECTRA_BIN"
        echo "     Ask for a QE module built with XSpectra."
    else
        echo "WARN xspectra.x: not found. Ask for a QE module built with XSpectra."
    fi

    if [ -n "${LD1_BIN:-}" ] && [ -x "$LD1_BIN" ]; then
        echo "PASS ld1.x: $LD1_BIN"
    elif [ -n "${LD1_BIN:-}" ]; then
        echo "WARN ld1.x: path is set but not executable: $LD1_BIN"
        echo "     Some tutorial checks may fail until this path is fixed."
    else
        echo "WARN ld1.x: not found. Some tutorial checks may fail until this path is fixed."
    fi

    if [ -n "${BIN_DIR:-}" ]; then
        echo "INFO BIN_DIR: $BIN_DIR"
    else
        echo "WARN BIN_DIR: not set. It is usually the folder printed by: dirname \"\$(command -v pw.x)\""
    fi

    if [ -n "${QE_ROOT:-}" ]; then
        echo "INFO QE_ROOT: $QE_ROOT"
    else
        echo "WARN QE_ROOT: not set. It is usually the parent folder of BIN_DIR."
    fi

    if [ -n "${TOOLS_DIR:-}" ] && [ -f "$TOOLS_DIR/upf2plotcore.sh" ]; then
        echo "PASS upf2plotcore.sh: $TOOLS_DIR/upf2plotcore.sh"
    elif [ -n "${TOOLS_DIR:-}" ]; then
        echo "WARN upf2plotcore.sh: missing at $TOOLS_DIR/upf2plotcore.sh"
        echo "     Ask the instructor for the correct TOOLS_DIR."
    else
        echo "WARN TOOLS_DIR: not set. Ask the instructor for the XSpectra tools directory."
    fi

    if [ -n "${EXAMPLE_PSEUDO_DIR:-}" ] && [ -f "$EXAMPLE_PSEUDO_DIR/C_PBE_TM_2pj.UPF" ]; then
        echo "PASS example pseudos: $EXAMPLE_PSEUDO_DIR"
    elif [ -n "${EXAMPLE_PSEUDO_DIR:-}" ]; then
        echo "WARN example pseudos: C_PBE_TM_2pj.UPF not found in $EXAMPLE_PSEUDO_DIR"
        echo "     Ask the instructor for the correct EXAMPLE_PSEUDO_DIR."
    else
        echo "WARN EXAMPLE_PSEUDO_DIR: not set. Ask the instructor for the XSpectra example pseudo directory."
    fi

    echo "INFO NPROCS: $NPROCS"
    echo "INFO MPI_RUN: $MPI_RUN"
    echo "INFO scratch: $XSPECTRA_SCRATCH"
    echo ""
    echo "Next step: bash check_setup.sh"
}

_XSPECTRA_ENV_PRINT_STATUS=0
if [ "${XSPECTRA_ENV_VERBOSE:-0}" = "1" ] || [ "$_XSPECTRA_ENV_RAN_AS_SCRIPT" = "1" ]; then
    _XSPECTRA_ENV_PRINT_STATUS=1
fi
case "$-" in
    *i*) _XSPECTRA_ENV_PRINT_STATUS=1 ;;
esac
if [ "${XSPECTRA_ENV_QUIET:-0}" = "1" ]; then
    _XSPECTRA_ENV_PRINT_STATUS=0
fi

if [ "$_XSPECTRA_ENV_PRINT_STATUS" = "1" ]; then
    _xspectra_env_print_status
fi

unset -f _xspectra_env_print_status
unset _XSPECTRA_ENV_PRINT_STATUS
unset _XSPECTRA_ENV_RAN_AS_SCRIPT
