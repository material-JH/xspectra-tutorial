#!/usr/bin/env bash
#PBS -N xspectra-sto-ok
#PBS -A qe
#PBS -l select=1:ncpus=4:mpiprocs=4
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

cd "$PBS_O_WORKDIR"
source ./env.sh

export NPROCS="${PBS_NP:-${NPROCS:-4}}"
export MPI_RUN="${MPI_RUN:-mpirun -np $NPROCS}"

cd SrTiO3/O_Kedge
bash run.sh
